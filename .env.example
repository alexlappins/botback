# Discord Bot Token (from https://discord.com/developers/applications → Bot)
DISCORD_TOKEN=your_bot_token_here

# OAuth2 для дашборда (то же приложение: Application ID = CLIENT_ID, OAuth2 → Client Secret)
DISCORD_CLIENT_ID=your_application_id
DISCORD_CLIENT_SECRET=your_client_secret
# URL, куда Discord перенаправит после входа (для локалки: http://localhost:3000/api/auth/callback)
DISCORD_CALLBACK_URL=http://localhost:3000/api/auth/callback

# Секрет для сессий (придумай свой длинный случайный ключ)
SESSION_SECRET=change-me-to-random-string

# Куда редиректить после входа/выхода, если фронт на отдельном порту (например Vite на 5173)
# Не задавай — редирект будет на / (удобно, когда фронт раздаётся с бэкенда)
# FRONTEND_URL=http://localhost:5173

# PostgreSQL (шаблоны сообщений и др.)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=car_user
POSTGRES_PASSWORD=car_pass
POSTGRES_DB=bot

# Только для разработки: ID тестового сервера — команды появятся сразу на нём.
# В продакшене не указывай: тогда команды регистрируются глобально.
# DISCORD_GUILD_ID=123456789012345678

# Twitch live notifications (https://dev.twitch.tv/console/apps).
# Без этих ключей модуль молча отключается — добавление каналов через
# /twitch add вернёт ошибку.
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
#
# Webhook callback. Twitch шлёт сюда события + initial challenge.
# Прод: публичный HTTPS URL твоего бэка, например https://api.example.com/api/twitch/webhook
# Локалка: ngrok-туннель на 3000 порт, типа https://abc123.ngrok.app/api/twitch/webhook
# TWITCH_WEBHOOK_CALLBACK_URL=
#
# Случайная строка ≥10 символов, должна быть НЕИЗМЕННОЙ — Twitch её запомнит
# при первой подписке и будет подписывать ей все следующие события.
# Сгенерировать: openssl rand -hex 32
# TWITCH_WEBHOOK_SECRET=

# ── Stripe (Premium subscription billing) ──
# STRIPE_SECRET_KEY=sk_live_...           # Dashboard → Developers → API keys
# STRIPE_WEBHOOK_SECRET=whsec_...         # created when you add the webhook endpoint
# STRIPE_PRICE_ID=price_...               # recurring Price of the Premium product
